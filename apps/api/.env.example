# Backend environment variables.
# Copy this file to .env for local development:  cp .env.example .env
# The default values below match the local MySQL container in ../../docker-compose.yml,
# so a fresh checkout works after `docker-compose up -d`.
#
# In production these are set by the host (Railway today, AWS later), never committed.

# Port the API listens on (see src/main.ts). Defaults to 3000 if unset.
PORT=3000

# MySQL connection.
# These names must match what the app reads in src/app.module.ts (process.env.MYSQL*).
# They are also the variable names Railway injects automatically for its MySQL service.
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=root
MYSQLDATABASE=autohaus_db

# Secret used to sign JWT auth tokens (see src/auth/auth.module.ts).
# Use a long, random value in production.
JWT_SECRET=supersecret_change_in_prod
