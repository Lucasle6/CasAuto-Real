# Copy to terraform.tfvars and adjust if you need non-default values.
# terraform.tfvars is gitignored on purpose - it's your local override file.

aws_region           = "eu-central-1"
availability_zone    = "eu-central-1a"
project_name         = "casauto"
environment          = "production"
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidr   = "10.0.1.0/24"
private_subnet_cidr  = "10.0.2.0/24"

# Restrict this to your own IP before applying, e.g. "203.0.113.4/32"
ssh_allowed_cidr     = "0.0.0.0/0"
backend_port         = 3000

mysql_instance_type  = "t3.micro"
mysql_database       = "autohaus_db"
mysql_app_user       = "app"

backend_instance_type = "t3.micro"
git_repo_url          = "https://github.com/Lucasle6/CasAuto-Real.git"
git_branch            = "main"

# mysql_app_password, mysql_root_password, and jwt_secret have NO default
# and are marked sensitive - do NOT put real values in this file (it's
# committed). Set them via terraform.tfvars (gitignored) or environment
# variables instead:
#   export TF_VAR_mysql_app_password="..."
#   export TF_VAR_mysql_root_password="..."
#   export TF_VAR_jwt_secret="..."
